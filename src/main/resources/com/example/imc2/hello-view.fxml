<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.imc2.HelloController">

    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <!-- Título -->
    <Label text="Painel de Monitoramento Corporativo">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>

    <Label text="Registro de Novo Usuário">
      <font>
         <Font size="14.0" />
      </font></Label>

    <!-- Área superior -->
    <HBox spacing="10">

        <!-- Formulário -->
        <VBox prefWidth="250" spacing="8">

            <Label text="Nome" />

            <TextField fx:id="inputName" promptText="Ex: Maria Silva" />

            <Label text="Email" />

            <TextField fx:id="inputEmail" promptText="exemplo@email.com" />

            <HBox spacing="10">

                <VBox>
                    <Label text="Peso (kg)" />
                    <TextField fx:id="txtPeso" />
                </VBox>

                <VBox>
                    <Label text="Altura (m)" />
                    <TextField fx:id="txtAltura" />
                </VBox>

            </HBox>

            <Button onAction="#onHelloButtonClick" text="Calcular e Adicionar" />

            <Label fx:id="lblResultado" />

        </VBox>

        <!-- Imagem -->
        <StackPane prefWidth="450.0">
            <ImageView fitHeight="180" fitWidth="350" preserveRatio="false">
            <image>
               <Image url="@pc.jpg" />
            </image></ImageView>
         <Label ellipsisString="" maxHeight="-Infinity" maxWidth="1000.0" prefHeight="85.0" prefWidth="378.0" text="Monitoramento Ativo" textFill="WHITE" textOverrun="CLIP" StackPane.alignment="CENTER_LEFT">
            <font>
               <Font name="System Bold" size="18.0" />
            </font>
            <padding>
               <Insets bottom="60.0" left="50.0" />
            </padding>
         </Label>
         <Label prefHeight="42.0" prefWidth="311.0" text="Acompanhe a evolução da saúde dos seus colaboradores em tempo real com relatórios detalhados" textFill="WHITE" wrapText="true">
            <StackPane.margin>
               <Insets right="37.0" />
            </StackPane.margin></Label>
        </StackPane>

    </HBox>

    <!-- Tabela -->
    <TableView fx:id="tabela">

        <columns>

            <TableColumn fx:id="colNome" prefWidth="180" text="Nome" />

            <TableColumn fx:id="colEmail" prefWidth="220" text="Email" />

            <TableColumn fx:id="colImc" prefWidth="100" text="IMC" />
         <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />

        </columns>

    </TableView>

</VBox>
